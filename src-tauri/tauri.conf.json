{
  "build": {
    "beforeDevCommand": "cls && yarn dev",
    "beforeBuildCommand": "cls && yarn build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "AthenaFN",
    "version": "1.0.23"
  },
  "tauri": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/TON_USER/TON_REPO/releases/latest/download/update.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI5OEFBNDA3NkY3QkVGQUQKUldTdDczdHZCNlNLS2ZDaWVMRHZ0SWZ6Szl6emVqMHN4VUdyemExVHZQNkNUYUZ6bGd5cGFkUkIK"
    },
    "allowlist": {
      "http": {
        "all": true,
        "request": true,
        "scope": [
          "http://127.0.0.1:3551/**",
          "http://localhost:5000/**",
          "http://athenafn.localhost:5000/**",
          "http://athenafn.localhost:3551/**"
        ]
      },
      "shell": {
        "all": true,
        "execute": true
      },
      "all": true,
      "protocol": {
        "all": true,
        "assetScope": ["*/**"]
      },
      "fs": {
        "all": true,
        "scope": ["*/**"]
      }
    },
    "windows": [
      {
        "fullscreen": false,
        "maximizable": true,
        "resizable": true,
        "title": "AthenaFN",
        "decorations": true,
        "center": true,
        "transparent": true,
        "minWidth": 1300,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": "default-src * 'unsafe-inline' 'unsafe-eval' data: blob:; img-src * data: blob:;"
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.project.app",
      "icon": [
        "icons/icon.icns",
        "icons/logo.ico"
      ],
      "resources": []
    }
  }
}
